BUTLER_ENV=development
BUTLER_LOG_LEVEL=INFO
BUTLER_AUTONOMY_LEVEL=2
# Defaults to ~/Library/Application Support/Butler
# BUTLER_DATA_DIR=/absolute/path/to/runtime/data

# Cyber Radar
BUTLER_TIMEZONE=Europe/Lisbon
BUTLER_RADAR_HOUR=7
BUTLER_RADAR_MINUTE=30
BUTLER_OMLX_BASE_URL=http://127.0.0.1:8000/v1
BUTLER_OMLX_MODEL=Qwen3.5-9B-OptiQ-4bit
BUTLER_SECURITYWORK_ROOT=/Users/raf/SecurityWork

# Private Data Breach Scanner event outbox
BUTLER_SCANNER_OUTBOX_ROOT=~/Library/Application Support/Data Breach Scanner/outbox

# Optional Telegram delivery. Prefer scripts/configure_telegram.sh, which stores these
# values in macOS Keychain instead of an environment file.
BUTLER_TELEGRAM_BOT_USERNAME=butleradelaidebot
# BUTLER_TELEGRAM_BOT_TOKEN=
# BUTLER_TELEGRAM_CHAT_ID=

# Optional manual-only cloud deep dives. Scheduled jobs never read these.
# BUTLER_CLOUD_BASE_URL=https://api.openai.com/v1
# BUTLER_CLOUD_MODEL=
# BUTLER_CLOUD_API_KEY=
